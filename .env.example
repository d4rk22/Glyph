# Glyph optional environment values.
# Copy values into Wrangler secrets, the Cloudflare dashboard, or a local
# `.dev.vars` file as appropriate. Do not commit real secrets.

# Optional public origin used when generating short links.
# PUBLIC_BASE_URL=https://files.example.com

# Optional direct-to-R2 and multipart upload configuration.
# R2_ACCOUNT_ID=00000000000000000000000000000000
# R2_ACCESS_KEY_ID=example-access-key-id
# R2_SECRET_ACCESS_KEY=example-secret-access-key
# R2_BUCKET_NAME=glyph-files
